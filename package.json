{
  "name": "noveltrad",
  "version": "2.0.0",
  "private": true,
  "description": "NovelTrad 2.0 — Multi-Agent Literary Translation Framework",
  "author": "Balrog57",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm run dev --workspace=apps/desktop",
    "build": "npm run build --workspace=apps/desktop",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "test": "npm run test --workspace=apps/desktop",
    "test:coverage": "npm run test:coverage --workspace=apps/desktop",
    "test:e2e": "npm run test:e2e --workspace=apps/desktop",
    "lint": "npm run lint --workspace=apps/desktop",
    "generate-latest-json": "npx tsx scripts/generate-latest-json.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "gpt-tokenizer": "^3.4.0"
  }
}
