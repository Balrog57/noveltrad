# NovelTrad OmegaT-compliant Project - .gitignore
# Generated for v1.1 project structure

# ============================================
# Project-Specific Files (Never Commit)
# ============================================

# Project metadata
project.json
config.json

# Translation Memory (may contain sensitive data)
project_save.tmx
project_save.tmx.bak
project_save.tmx.timestamp.bak
tm/**/*.tmx

# User-specific UILayout
uiLayout.xml

# Last position marker
last_entry.properties

# ============================================
# Backup & Snapshots (Local Only)
# ============================================

# Automatic backups
backup/
snapshots/
!snapshots/.gitkeep

# ============================================
# Temporary & Cache Files
# ============================================

*.tmp
*.temp
*.swp
*.swo
*~
.cache/
__pycache__/
.pytest_cache/

# ============================================
# IDE & Editor Files
# ============================================

.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# ============================================
# Log Files
# ============================================

*.log
logs/

# Local pipeline / smoke-test state stores
*.db
*.db-shm
*.db-wal

# ============================================
# build_script.py & Deployment
# ============================================

build/
dist/
*.spec
!build.spec

# ============================================
# AI Agents & Virtual Environments
.agents/
.gemini/
.kilo/
tasks/
OmegaT_Doc/
.env
.venv/
env/
venv/
*.egg-info/
.noveltrad/
*.ntrad
