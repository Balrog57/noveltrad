{"nodes": [{"id": "docs_volumes_25_prompt_book", "label": "Prompt Book (Volume 25)", "file_type": "document", "source_file": "docs/volumes/25-Prompt-Book.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_volumes_25_prompt_book_prompt_chaining", "label": "Prompt Chaining Pipeline", "file_type": "rationale", "source_file": "docs/volumes/25-Prompt-Book.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sequential agent chain: Split \u2192 Pre-translate \u2192 Translate (source + lexicon + TM) \u2192 Consistency \u2192 Lexicon \u2192 Grammar \u2192 Style \u2192 Polish \u2192 QA \u2192 Export. Each agent receives previousOutput. Split and Export are non-AI (regex/formatting)."}, {"id": "docs_volumes_25_prompt_book_fallback_strategies", "label": "AI Fallback Strategies", "file_type": "rationale", "source_file": "docs/volumes/25-Prompt-Book.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Four fallback scenarios: invalid JSON output (retry with json-fix prompt, max 2 attempts then mark failed), ethical refusal (reformulate as fictional analysis, 2 retries then switch provider), provider unavailable (3 retries with backoff then fallback provider), token limit exceeded (chunk text, process separately, reassemble)."}, {"id": "docs_volumes_25_prompt_book_versioning", "label": "Prompt Versioning", "file_type": "rationale", "source_file": "docs/volumes/25-Prompt-Book.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prompts stored in prompts table (SQLite) with id, agent_id, version, role, content, created_at. Engine uses latest version unless user pins specific version. Frontmatter YAML: id, version, agent, role, language, target_model, output_format."}, {"id": "docs_volumes_25_prompt_book_model_compatibility", "label": "Model Compatibility Matrix", "file_type": "rationale", "source_file": "docs/volumes/25-Prompt-Book.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Primary model: qwen3.5:9b for all 8 AI agents. Fast alternative: qwen3.5:4b. Models <4B not recommended for JSON-output agents (consistency, lexicon, grammar, QA). Context window should be at least 2x chunk size."}, {"id": "qwen_3_5_model_family", "label": "qwen3.5 Model Family (9b/4b)", "file_type": "concept", "source_file": "docs/volumes/25-Prompt-Book.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "docs_volumes_25_prompt_book_prompt_chaining", "target": "qwen_3_5_model_family", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/volumes/25-Prompt-Book.md", "source_location": null, "weight": 1.0}, {"source": "docs_volumes_25_prompt_book_prompt_chaining", "target": "docs_volumes_25_prompt_book_fallback_strategies", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/volumes/25-Prompt-Book.md", "source_location": null, "weight": 1.0}, {"source": "docs_volumes_25_prompt_book_fallback_strategies", "target": "docs_volumes_22_performance_oom_handling", "relation": "semantically_similar_to", "confidence": "INFERRED", "confidence_score": 0.65, "source_file": "docs/volumes/25-Prompt-Book.md", "source_location": null, "weight": 1.0}, {"source": "docs_volumes_25_prompt_book_versioning", "target": "docs_volumes_14_history", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.65, "source_file": "docs/volumes/25-Prompt-Book.md", "source_location": null, "weight": 1.0}, {"source": "docs_volumes_25_prompt_book_model_compatibility", "target": "docs_volumes_25_prompt_book_prompt_chaining", "relation": "rationale_for"