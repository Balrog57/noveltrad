{"nodes": [{"id": "workflow_state", "label": "Workflow State - Canonical Handoff Record", "file_type": "document", "source_file": "WORKFLOW_STATE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_plugin_system", "label": "Plugin System (SDD Volume 15)", "file_type": "concept", "source_file": "WORKFLOW_STATE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_structured_logging", "label": "Structured Logging (NDJSON)", "file_type": "rationale", "source_file": "WORKFLOW_STATE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The StructuredLogger class produces NDJSON output with redaction of sensitive keys, correlation IDs, and 1000-char message truncation. It implements child() and withCorrelationId() for composable logging."}, {"id": "concept_esm_cache_busting", "label": "ESM Cache Busting for Plugin Hot-Reload", "file_type": "rationale", "source_file": "WORKFLOW_STATE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "ESM modules are permanently cached by the module loader with no equivalent to delete require.cache. Solution: query-string cache busting in dev mode (import(`./plugin/index.mjs?t=${Date.now()}`)). In production, reload requires app restart."}, {"id": "concept_electron_sandbox", "label": "Electron Sandbox Security", "file_type": "rationale", "source_file": "WORKFLOW_STATE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "SDD Volume 21 requires sandbox: true in webPreferences. The sandbox was changed from false to true as part of security hardening, complying with Electron's security best practices for renderer isolation."}, {"id": "concept_permissions_flow", "label": "Deferred Plugin Permissions Confirmation", "file_type": "rationale", "source_file": "WORKFLOW_STATE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "PluginHost discovers plugins at startup, identifies those with sensitive permissions (project-write, fs-write, network), and defers activation until after createWindow() when the renderer can display a confirmation modal to the user. This solves the chicken-and-egg problem of needing UI before plugins are loaded."}, {"id": "concept_export_engine_extensibility", "label": "ExportEngine Extensibility via customRenderers", "file_type": "rationale", "source_file": "WORKFLOW_STATE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "ExportEngine gains a Map<ExportFormat, CustomRenderer> and public registerRenderer/unregisterRenderer methods. In render(), custom renderers are checked before the built-in switch, allowing plugins to add or override export formats without modifying ExportEngine source."}], "edges": [{"source": "workflow_state", "target": "concept_plugin_system", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "WORKFLOW_STATE.md", "source_location": null, "weight": 1.0}, {"source": "workflow_state", "target": "concept_sdd_volumes", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "WORKFLOW_STATE.md", "source_location": null, "weight": 1.0}, {"source": "workflow_state", "target": "concept_context7", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "WORKFLOW_STATE.md", "source_location": null, "weight": 1.0}, {"source": "workflow_state", "target": "concept_esm_cache_busting", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "WORKFLOW_STATE.md", "source_location": null, "weight": 1.0}, {"source": "workflow_state", "target": "con