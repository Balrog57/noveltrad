{"nodes": [{"id": "docs_volumes_22_performance", "label": "Performance Optimizations (Volume 22)", "file_type": "document", "source_file": "docs/volumes/22-Performance.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_volumes_22_performance_cache_strategy", "label": "Multi-layer Cache Strategy", "file_type": "rationale", "source_file": "docs/volumes/22-Performance.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Five cache types: AI responses (TTL 7 days, hash key), embeddings (SQLite, invalidated on model change), parse (file hash), TM (persistent SQLite), export (TTL 1 day). Global size limit 1GB with LRU eviction."}, {"id": "docs_volumes_22_performance_worker_threads", "label": "Worker Thread Parallelism", "file_type": "rationale", "source_file": "docs/volumes/22-Performance.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "CPU-bound agents (parsing, consistency, export) run in Worker threads. Communication via parentPort.postMessage with JSON messages. Ollama concurrency limited to 1 job by default (maxConcurrentJobs). Promise.all for independent calls."}, {"id": "docs_volumes_22_performance_oom_handling", "label": "OOM Prevention Strategy", "file_type": "rationale", "source_file": "docs/volumes/22-Performance.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Hard limits: max source file 50MB, max paragraphs in memory 10,000, max AI batch 8,000 tokens. On OOM detection: reduce batch size and retry, clear temp caches after each job."}, {"id": "docs_volumes_22_performance_benchmarks", "label": "Performance Benchmarks", "file_type": "rationale", "source_file": "docs/volumes/22-Performance.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contri