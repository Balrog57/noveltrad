  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/adm-zip": "^0.5.8",
    "@types/diff-match-patch": "^1.0.36",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/sbd": "^1.0.5",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vitest/coverage-v8": "^2.0.0",
    "@vue/test-utils": "^2.4.11",
    "electron": "^31.1.0",
    "electron-builder": "^24.13.3",
