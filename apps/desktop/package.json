{
  "name": "@noveltrad/desktop",
  "version": "2.2.2",
  "private": true,
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run type-check && electron-vite build && electron-builder",
    "postinstall": "node ../../scripts/7za-wrapper/install.cjs",
    "preview": "electron-vite preview",
    "type-check": "vue-tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.vue",
    "format": "prettier --write .",
    "verify": "npm run lint && npm run type-check && npm run test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "@noveltrad/shared": "*",
