    "chardet": "^2.0.0",
    "cheerio": "^1.2.0",
    "compute-cosine-similarity": "^1.1.0",
    "diff-match-patch": "^1.0.5",
    "docx": "^8.5.0",
    "electron-log": "^5.1.7",
    "electron-updater": "^6.3.0",
    "epub-gen-memory": "^1.1.2",
    "fast-levenshtein": "^2.0.6",
    "fast-xml-parser": "^5.9.3",
    "franc": "^6.2.0",
    "gpt-tokenizer": "^3.4.0",
    "iconv-lite": "^0.6.3",
    "jsdom": "^24.1.0",
    "mammoth": "^1.8.0",
    "minisearch": "^7.2.0",
    "node-sqlite3-wasm": "^0.8.59",
    "openai": "^4.104.0",
    "p-queue": "^9.3.1",
    "p-retry": "^8.0.0",
    "pinia": "^2.1.7",
    "sbd": "^1.0.19",
    "uuid": "^10.0.0",
    "vue": "^3.4.31",
    "vue-router": "^4.4.0",
    "zod": "^3.23.8"
