{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/src/*"],
      "@main/*": ["src/main/*"],
      "@shared/*": ["../../packages/shared/src/*"],
      "@scripts/*": ["../../scripts/*"]
    },
    "types": ["electron-vite/node", "vitest/globals"]
  },
  "include": ["src/**/*", "tests/**/*"]
}
